Options -Indexes
RewriteEngine On

# Static files pass through
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Products
RewriteRule ^products/([^/]+)/([^/]+)/?$ /wavicle_v5/catalog-item.php?cat=$1&slug=$2 [L,QSA]
RewriteRule ^products/([^/]+)/?$ /wavicle_v5/catalog-category.php?slug=$1 [L,QSA]
RewriteRule ^products/?$ /wavicle_v5/courses.php [L,QSA]

# Services
RewriteRule ^services/([^/]+)/([^/]+)/?$ /wavicle_v5/catalog-item.php?cat=$1&slug=$2 [L,QSA]
RewriteRule ^services/([^/]+)/?$ /wavicle_v5/catalog-category.php?slug=$1 [L,QSA]
RewriteRule ^services/?$ /wavicle_v5/index.php [L,QSA]

# News
RewriteRule ^news/([^/]+)/?$ /wavicle_v5/news-detail.php?slug=$1 [L,QSA]
RewriteRule ^news/?$ /wavicle_v5/news.php [L,QSA]
